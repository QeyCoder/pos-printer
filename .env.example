# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# Bind to 0.0.0.0 to accept from Tailscale interface.
# Change to your Tailscale IP (100.x.x.x) to be extra strict.
HOST=0.0.0.0

# ─── Security ─────────────────────────────────────────────────────────────────
# Change this to a long random string. Your POS must send it as:
#   X-API-Key: <value>
API_KEY=change-me-to-a-long-random-secret

# ─── Printer ──────────────────────────────────────────────────────────────────
# USB thermal printer device path.
# Run: ls /dev/usb/ or ls /dev/ttyUSB*  to find yours.
# Most USB thermal printers show up as /dev/usb/lp0
PRINTER_INTERFACE=/dev/usb/lp0

# Printer type — leave as EPSON for any generic ESC/POS printer
PRINTER_TYPE=EPSON

# Paper width in characters (80mm paper = 48 chars, 58mm paper = 32 chars)
PRINTER_WIDTH=48

# Character set — use PC437_USA for English, PC437_INDIA for Indian chars
PRINTER_CHAR_SET=PC437_USA

# ─── Receipt Defaults ─────────────────────────────────────────────────────────
# Used as fallback if not provided in the print request
DEFAULT_RESTAURANT_NAME=My Restaurant
DEFAULT_FOOTER=Thank you! Please visit again.
